repos:
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: {{ ruff_version | default("v0.8.6") }}
    hooks:
      - id: ruff
        args: [--fix]
      - id: ruff-format

  - repo: https://github.com/pre-commit/mirrors-mypy
    rev: {{ mypy_version | default("v1.14.1") }}
    hooks:
      - id: mypy
        additional_dependencies: [pydantic]
